# Copie para .env.local e preencha. NUNCA comite .env.local.
FIRECRAWL_API_KEY=            # chave do Firecrawl (coleta de conteudo)

# MOTOR LLM — dois providers. O ESCOLHIDO e por-org (padrao DeepSeek), trocavel
# pelo super_admin no /admin; o outro fica como fallback automatico.
#  - DeepSeek (padrao): API OpenAI-compativel. Sem a chave, o Radar cai no Claude.
DEEPSEEK_API_KEY=             # chave da API DeepSeek (provider padrao)
# DEEPSEEK_BASE_URL=https://api.deepseek.com          # opcional
# DEEPSEEK_MODEL=deepseek-chat                         # opcional (effort:high -> reasoner)
# DEEPSEEK_MODEL_REASONER=deepseek-reasoner            # opcional
# LLM_PROVIDER=claude          # opcional: muda o DEFAULT do sistema (senao deepseek)
#  - Claude: subscricao via gateway na VPS (reuso do Formare) — NUNCA removido.
LLM_GATEWAY_URL=              # motor Claude na VPS (gateway) - reuso do Formare
LLM_GATEWAY_SECRET=

# Porta estreita de LEITURA do Brain (F3) — o Radar le conhecimento CONFIRMADO
# do cliente. O Radar NUNCA tem a credencial do banco do Formare.
RADAR_BRAIN_URL=http://localhost:8090/brain
RADAR_BRAIN_SECRET=           # o mesmo segredo do radar-door

# Porta estreita de ESCRITA (bilhetes -> aba Revisar do Formare).
# DESLIGADA por padrao — descomentar SO com OK do Rafael (e ligar a porta).
# RADAR_INTAKE_URL=http://localhost:8090/intake
# RADAR_INTAKE_SECRET=

# Banco PROPRIO do Radar (eventos crus) - a criar em fase futura:
# RADAR_SUPABASE_URL=
# RADAR_SUPABASE_SERVICE_ROLE_KEY=

# Meta Ad Library API (Lente 3 do diagnostico — midia paga oficial).
# Token LONGO (~60 dias). Setup: docs/meta-ad-library-setup.md
# Sem token, a Lente 3 cai no scrape best-effort (quase sempre "nao localizado").
META_AD_LIBRARY_TOKEN=

# Fechadura do app (login principal) — exigida em producao
RADAR_APP_EMAIL=
RADAR_APP_PASSWORD=
# Usuarios extras (multi-usuario): "email:senha" separados por virgula.
# Ex.: fulano@x.com:segredo,ciclana@y.com:outra
# RADAR_APP_USERS=
